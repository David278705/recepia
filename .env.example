APP_NAME=RecepIA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/vigia/public

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vigia
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# RecepIA - Agente de IA recepcionista de WhatsApp 24/7
# ---------------------------------------------------------------------------

# Claude API (Anthropic) - el agente recepcionista
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# WhatsApp Business Cloud API (Coexistence) - conversación con clientes.
# App Secret y verify token son a nivel de la app de Meta (una sola vez, no
# por negocio): firman/validan el webhook único global POST /webhooks/whatsapp.
# El token de acceso y phone_number_id de cada negocio se configuran desde el
# panel de admin (tabla whatsapp_accounts), no aquí.
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=v21.0
# Máximo de requests/minuto por IP al webhook (agrega el tráfico de todos los negocios)
WHATSAPP_WEBHOOK_RATE_LIMIT=300

# Comportamiento para mensajes no soportados en el MVP (audio/imagen/ubicación):
# 'reply' (responde con texto fijo) o 'escalate' (escala al dueño)
WHATSAPP_UNSUPPORTED_MESSAGE_ACTION=reply
# Minutos que el bot se silencia en una conversación tras un echo del dueño
WHATSAPP_BOT_PAUSE_MINUTES=30

# Opcional: credenciales de un número real para que el seeder de demo conecte
# el negocio de ejemplo a WhatsApp de verdad en vez de usar datos ficticios.
WHATSAPP_DEMO_PHONE_NUMBER_ID=
WHATSAPP_DEMO_ACCESS_TOKEN=
WHATSAPP_DEMO_WABA_ID=
WHATSAPP_DEMO_PHONE_E164=

# ── Wompi (suscripciones / pagos recurrentes) ────────────────────────────────
# Consíguelas en https://comercios.wompi.co → Desarrolladores → Llaves de API.
# Usa las llaves de prueba (pub_test_/prv_test_) con el sandbox y cambia a las
# de producción (pub_prod_/prv_prod_) junto con WOMPI_BASE_URL al salir en vivo.
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
# Secreto de EVENTOS (pestaña "Eventos" en el panel de Wompi): firma los
# webhooks. Configura allí la URL: https://tu-dominio.com/api/webhooks/wompi
WOMPI_EVENTS_SECRET=

# Días de gracia para pagar la renovación después de que vence el periodo
# (el panel sigue accesible mientras corre este plazo).
SUBSCRIPTION_GRACE_DAYS=5
# Secreto de INTEGRIDAD (misma página de llaves): firma las transacciones y el
# Widget de checkout. Obligatorio.
WOMPI_INTEGRITY_SECRET=
